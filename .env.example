# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stockdb

# Cache
REDIS_URL=redis://localhost:6379/0

# Message broker
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Groq
GROQ_API_KEY=your_groq_api_key_here

# ── Broker selection ───────────────────────────────────────────────────────────
# BROKER=paper   No account needed. Uses yfinance prices + local Postgres. (default)
# BROKER=upstox  Upstox sandbox or live. Set access token below.
# BROKER=angel   Angel One live trading. Requires Demat + pip install smartapi-python pyotp
BROKER=paper

# Paper broker starting balance (₹)
PAPER_STARTING_CASH=1000000

# ── Upstox (only needed when BROKER=upstox) ───────────────────────────────────
# Get access_token via OAuth2: https://developer.upstox.com/docs/login-workflow
# Token expires every trading day — re-run the OAuth flow to refresh it.
UPSTOX_ACCESS_TOKEN=
UPSTOX_SANDBOX=true

# ── Angel One SmartAPI (only needed when BROKER=angel) ────────────────────────
# Requires pip install smartapi-python pyotp and a live Demat account.
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# News (optional — Indian RSS feeds work without this)
NEWSAPI_KEY=

# App
PAPER_MODE=true
LOG_LEVEL=INFO
DEFAULT_EXCHANGE=NSE
CURRENCY=INR

# Celery (mirrors broker/backend above)
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/0
